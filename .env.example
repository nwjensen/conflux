# Copy to .env and adjust. All values have safe defaults.

# --- Security ---
# Operator PIN guarding the state override endpoint. CHANGE THIS.
CONFLUX_OVERRIDE_PIN=0000

# --- Deployment ---
# Host port to expose the Family Command Hub on.
CONFLUX_PORT=8080
# PostgreSQL password (Compose).
CONFLUX_DB_PASSWORD=conflux

# --- Behaviour ---
# Real-world timing is TIME_SCALE=1.0. Use a small value for demos so the
# absence ladder (OK -> Delayed -> Need Contact) plays out in seconds.
#   e.g. 0.03 turns the 10-minute absence window into ~18s.
CONFLUX_TIME_SCALE=1.0

# SMS scheduling. 0 == Phase 1 clock-gating to :00 / :30. A positive value sets
# a fixed cadence in seconds (handy for demos).
CONFLUX_SMS_INTERVAL_SECONDS=0

# Built-in input simulator (drives subjects without real radios). Turn off when
# wiring real APRS / Meshtastic adapters.
CONFLUX_SIMULATOR=true

# Subjects seeded on first start (only when the registry is empty).
# Format: Name:CALLSIGN,Name:CALLSIGN  (callsign optional)
CONFLUX_SEED_SUBJECTS=Dad:KE0ABC,Mom:KE0DEF,Teen:KE0GHI

# Background evaluation cadence (seconds).
CONFLUX_TICK_INTERVAL=5

# CW (Morse) auto-keying. Phase 1 default: off.
CONFLUX_CW_ENABLED=false

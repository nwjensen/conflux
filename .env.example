# Copy to .env and adjust. All values have safe defaults.

# --- Security ---
# Operator PIN guarding the state override endpoint. CHANGE THIS.
CONFLUX_OVERRIDE_PIN=0000

# --- Deployment ---
# Host port to expose the Family Command Hub on.
CONFLUX_PORT=8080
# PostgreSQL password (Compose).
CONFLUX_DB_PASSWORD=conflux

# --- Behaviour ---
# Real-world timing is TIME_SCALE=1.0. Use a small value for demos so the
# absence ladder (OK -> Delayed -> Need Contact) plays out in seconds.
#   e.g. 0.03 turns the 10-minute absence window into ~18s.
CONFLUX_TIME_SCALE=1.0

# SMS scheduling. 0 == Phase 1 clock-gating to :00 / :30. A positive value sets
# a fixed cadence in seconds (handy for demos).
CONFLUX_SMS_INTERVAL_SECONDS=0

# Built-in input simulator (drives subjects without real radios). Turn off when
# wiring real APRS / Meshtastic adapters.
CONFLUX_SIMULATOR=true

# Subjects seeded on first start (only when the registry is empty).
# Format: Name:CALLSIGN,Name:CALLSIGN  (callsign optional)
CONFLUX_SEED_SUBJECTS=Dad:KE0ABC,Mom:KE0DEF,Teen:KE0GHI

# Background evaluation cadence (seconds).
CONFLUX_TICK_INTERVAL=5

# CW (Morse) auto-keying. Phase 1 default: off.
CONFLUX_CW_ENABLED=false

# --- APRS-IS input adapter (real position input) ---
# Off by default (the simulator covers development). Turn on to ingest live
# position reports for subjects whose callsign matches the packet sender.
CONFLUX_APRS_ENABLED=false
# Your amateur callsign for APRS-IS login. Receive-only works with passcode -1.
# A placeholder like N0CALL is rejected by most servers — use your real call.
CONFLUX_APRS_CALLSIGN=N0CALL
CONFLUX_APRS_PASSCODE=-1
CONFLUX_APRS_HOST=rotate.aprs2.net
CONFLUX_APRS_PORT=14580
# Leave blank to auto-build a filter from your subjects' callsigns.
CONFLUX_APRS_FILTER=
# Movement thresholds: moving if speed > SPEED_KMH, else if it moved > MOVE_M.
CONFLUX_APRS_SPEED_KMH=3.0
CONFLUX_APRS_MOVE_M=50.0

# --- aprs.fi poller (position via the aprs.fi HTTP API) ---
# A pull alternative to APRS-IS: use when a subject's position lives in aprs.fi
# (e.g. its browser "share location" feature) but never hits the APRS-IS network.
# Matches subjects by callsign exactly as the APRS-IS adapter does.
CONFLUX_APRSFI_ENABLED=false
# Free API key from https://aprs.fi/account/ (log in -> "My account" -> API key).
CONFLUX_APRSFI_API_KEY=
# Poll cadence in seconds. aprs.fi asks for <= 1 request/min; 30s is the floor.
CONFLUX_APRSFI_POLL=60
# Ignore fixes older than this (hours). aprs.fi returns the last-known position
# regardless of age; 0 disables the guard.
CONFLUX_APRSFI_MAX_AGE_HOURS=24

# --- Basemap tiles (Family Command Hub map) ---
# The hub never talks to a tile server directly: it fetches tiles from Conflux,
# which caches them on disk. Areas that have been viewed keep drawing when the
# internet is down. Point the cache at a path the service user can write.
CONFLUX_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
CONFLUX_TILE_CACHE_DIR=/var/lib/conflux/tiles
# Soft cap; least-recently-written tiles are evicted past it.
CONFLUX_TILE_CACHE_MB=256
# Re-fetch a cached tile once it is this old (0 = never expire).
CONFLUX_TILE_MAX_AGE_DAYS=30
# false = serve only what is already cached (fully offline basemap).
CONFLUX_TILE_UPSTREAM=true
